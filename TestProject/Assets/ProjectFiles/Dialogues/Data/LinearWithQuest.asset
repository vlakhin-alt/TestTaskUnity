  nodes:
  - nodeID: Start
    npcText: "\u041F\u0440\u0438\u0432\u0435\u0442, \u042F \u0441\u043D\u0435\u0433\u043E\u0432\u0438\u043A,
      \u043F\u043E\u043C\u043E\u0433\u0438 \u043C\u043D\u0435! "
    options:
    - optionText: "\u041A\u0430\u043A \u0442\u0435\u0431\u0435 \u043F\u043E\u043C\u043E\u0447\u044C?"
      nextNodeID: Description
      action: 
    isEndNode: 0
    questAction: 
    questParameter: 
  - nodeID: Description
    npcText: "\u041C\u043D\u0435 \u043D\u0443\u0436\u0435\u043D \u043E\u0434\u0438\u043D
      \u043F\u0440\u0435\u0434\u043C\u0435\u0442 , \u043E\u043D  \u043D\u0430 \u0441\u0442\u043E\u043B\u0435."
    options:
    - optionText: "\u0414\u0430, \u043A\u043E\u043D\u0435\u0447\u043D\u043E, \u0441\u0435\u0439\u0447\u0430\u0441
        \u043F\u0440\u0438\u043D\u0435\u0441\u0443."
      nextNodeID: Activation
      action: 
    isEndNode: 0
    questAction: 
    questParameter: 
  - nodeID: Activation
    npcText: "\u041E\u0442\u043B\u0438\u0447\u043D\u043E, \u044F \u043E\u0442\u043C\u0435\u0447\u0443
      \u0443 \u0442\u0435\u0431\u044F \u0432 \u0436\u0443\u0440\u043D\u0430\u043B\u0435,
      \u0447\u0442\u043E\u0431\u044B \u0442\u044B \u043D\u0435 \u0437\u0430\u0431\u044B\u043B."
    options:
    - optionText: "\u0421\u0443\u043F\u0435\u0440"
      nextNodeID: Wait
      action: 
    isEndNode: 0
    questAction: ActivateQuest
    questParameter: 
  - nodeID: Wait
    npcText: "\u0416\u0434\u0443 \u0442\u0435\u0431\u044F."
    options:
    - optionText: "\u0421\u043A\u043E\u0440\u043E \u0431\u0443\u0434\u0443."
      nextNodeID: 
      action: CloseDialogue
    isEndNode: 0
    questAction: 
    questParameter: 
  - nodeID: QuestComplete
    npcText: "\u0411\u043B\u0430\u0433\u043E\u0434\u0430\u0440\u044E, \u0442\u044B
      \u043C\u0435\u043D\u044F \u0432\u044B\u0440\u0443\u0447\u0438\u043B!"
    options:
    - optionText: "\u041E\u0431\u0440\u0430\u0449\u0430\u0439\u0441\u044F!"
